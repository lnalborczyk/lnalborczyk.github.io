  geom_path(aes(colour = "orangered"), stat = "function", fun = f5, lwd = 1) +
  labs(x = "x", y = "f(x)") +
  scale_colour_identity(
    "Function", guide = "legend",
    labels = c("y = exp(-0.5x^2)", "derivative"),
    breaks = c("steelblue", "orangered")
    ) +
  theme_bw(base_size = 20)
```

