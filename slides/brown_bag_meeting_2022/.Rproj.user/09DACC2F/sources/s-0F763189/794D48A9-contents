# Modèle de régression logistique

```{r prior7, eval = TRUE, echo = TRUE}
prior7 <- c(
    prior(normal(0, 10), class = Intercept, coef = ""),
    prior(normal(0, 5), class = b),
    prior(cauchy(0, 10), class = sd),
    prior(lkj(2), class = cor)
    )
```

```{r mod7, eval = TRUE, echo = TRUE, results = "hide", message = FALSE, warning = FALSE}
mod7 <- brm(
    presence | trials(total) ~ 1 + reminder + (1 + reminder | researcher), 
    family = binomial(link = "logit"),
    prior = prior7,
    data = data,
    sample_prior = TRUE,
    file = "models/mod7.rds",
    warmup = 2000, iter = 1e4,
    cores = parallel::detectCores(),
    control = list(adapt_delta = 0.95) )
```

