dat <- c(1, 0, 1)
ac <- c(1.2, 0.9, 0.6)
arc <- c( pi / 2, pi / 2 + (2 / 3) * pi)
garden(
arc = arc,
possibilities = c(1, 0, 0, 0),
data = dat,
hedge = 0.05,
adj.cex = ac)
arc <- c(arc[2], arc[2] + (2 / 3) * pi)
garden(
arc = arc,
possibilities = c(1, 1, 0, 0),
data = dat,
hedge = 0.05,
newplot = FALSE,
adj.cex = ac)
arc <- c(arc[2], arc[2] + (2 / 3) * pi)
garden(
arc = arc,
possibilities = c(1, 1, 1, 0),
data = dat,
hedge = 0.05,
newplot = FALSE,
adj.cex = ac)
